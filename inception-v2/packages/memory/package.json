{
  "name": "@rabeluslab/inception-memory",
  "version": "2.0.0",
  "description": "Lossless hybrid memory backend (SQLite + DAG summaries + embeddings) for Inception Framework",
  "license": "MIT",
  "author": "Rabelus Lab",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@rabeluslab/inception-types": "workspace:*",
    "@rabeluslab/inception-core": "workspace:*",
    "@google/generative-ai": "^0.21.0",
    "ollama": "^0.5.0"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "rimraf": "^5.0.5",
    "vitest": "^1.3.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
