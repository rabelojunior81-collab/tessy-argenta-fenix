{
  "name": "@rabeluslab/inception-channel-telegram",
  "version": "2.0.0",
  "description": "Telegram Bot channel for Inception Framework (grammy-based, polling + webhook)",
  "license": "MIT",
  "author": "Rabelus Lab",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rabeluslab/inception-types": "workspace:*",
    "@rabeluslab/inception-core": "workspace:*",
    "grammy": "^1.21.1"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "rimraf": "^5.0.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
